# Calibre Web credentials for `ade-dedrm upload` and `ade-dedrm decrypt --upload`.
#
# Copy this file to `.env` in your working directory (or to
# `~/.config/ade-dedrm/.env`) and fill in the values. Process
# environment variables with the same names override these entries.

ADE_DEDRM_CALIBRE_URL=http://localhost:8083
ADE_DEDRM_CALIBRE_USERNAME=admin
ADE_DEDRM_CALIBRE_PASSWORD=change-me

# Set to "false" to skip TLS verification (self-signed certs).
# ADE_DEDRM_CALIBRE_VERIFY_TLS=true
